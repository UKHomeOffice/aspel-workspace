{
  "compilerOptions": {
	"target": "ES2022",
	"module": "NodeNext",
	"moduleResolution": "NodeNext",
	"rootDir": ".",
	"strict": true,
	"esModuleInterop": true,
	"forceConsistentCasingInFileNames": true,
	"skipLibCheck": true,
	"types": ["node"],
	"lib": ["ES2022", "DOM"]
  },
  "include": [
	"scripts/**/*.ts",
	"types/**/*.d.ts"
  ],
  "exclude": [
	"node_modules"
  ]
}

