{
  "extends": ["@ukhomeoffice/asl"],
  "ignorePatterns": [
    "dist/**"
  ],
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "env": {
    "node": true
  },
  "rules": {
    "generator-star-spacing": [
      "error", {
        "before": false,
        "after": true
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/*.ts"
      ],
      "parser": "@typescript-eslint/parser",
      "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
      }
    },
    {
      "files": [
        "tests/**/*.js"
      ],
      "rules": {
        "implicit-dependencies/no-implicit": [
          "error",
          {
            "dev": true
          }
        ]
      }
    }
  ]
}
